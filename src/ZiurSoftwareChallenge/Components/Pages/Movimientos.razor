@page "/movimientos"
@using ZiurSoftwareChallenge.Models
@using ZiurSoftwareChallenge.Services
@inject IMovimientoService Servicio

<div class="container mt-5">
    <h1 class="mb-4">Movimientos</h1>

    @if (movimientos == null)
    {
        <div class="alert alert-info" role="alert">
            <div class="spinner-border spinner-border-sm me-2" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            Cargando datos...
        </div>
    }
    else if (movimientos.Count == 0)
    {
        <div class="alert alert-warning" role="alert">
            No hay movimientos disponibles.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Código</th>
                        <th scope="col">Descripción</th>
                        <th scope="col">Activa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in movimientos)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-primary">@item.Codigo</span>
                            </td>
                            <td>@item.Descripcion</td>
                            <td>
                                @if (item.VActiva)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Movimiento>? movimientos;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movimientos = await Servicio.ObtenerMovimientosAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar movimientos: {ex.Message}");
            movimientos = new List<Movimiento>();
        }
    }
}
